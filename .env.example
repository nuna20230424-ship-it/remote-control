# remotectl 환경변수 예시 — 실제 값은 .env 로 복사해 채운다 (.env 는 커밋 금지)

# ── 구현체 선택 (config.Settings) ────────────────────────────────
# driver_backend: mock | mcp
REMOTECTL_DRIVER_BACKEND=mock
# sense_backend: mock | detection
REMOTECTL_SENSE_BACKEND=mock
# 맵 영속화 경로 (JSON)
REMOTECTL_MAP_STORE_PATH=./data/navmap.json
# 키이벤트↔화면 매핑 별도 DB (SQLite)
REMOTECTL_KEYSCREEN_DB=./data/keyscreen.db
# press 후 화면 안정화 대기(ms)
REMOTECTL_SETTLE_MS=400
# 오류 자가치유 최대 재시도(스텝당). REOBSERVE 는 detection-mcp VLM 재판정을 트리거.
REMOTECTL_RECONCILE_MAX_ATTEMPTS=2

# ── ir-mcp (리모컨 제어) — 실물 계약: POST /send {codeset,key} ───
# base URL. IR_MCP_URL 우선, 없으면 REMOTE_MCP_URL 로 폴백.
IR_MCP_URL=http://172.16.3.136:8002
# 대상 단말/리모컨에 맞는 코드셋 (예: ref_remote | kt_new | android_tv)
REMOTECTL_IR_CODESET=ref_remote
REMOTE_MCP_TOKEN=
REMOTE_MCP_TIMEOUT=10
# reset 엔드포인트가 없어 HOME 키 반복으로 시작점 복귀 (횟수)
REMOTECTL_RESET_HOME_PRESSES=1

# ── capture-mcp (화면 캡처) — 실물 계약: POST /capture → MP4 파일 ─
# 미설정이면 화면 캡처 미가용. 영상에서 ffmpeg 로 프레임 추출(ffmpeg 필요).
# file_path 를 이 프로세스가 읽을 수 있어야 함(capture-mcp 와 공유 볼륨).
CAPTURE_MCP_URL=http://172.16.3.136:8001
REMOTECTL_CAPTURE_TARGET=dut
REMOTECTL_CAPTURE_DURATION_SEC=1

# ── detection-mcp / VLM (화면 판정) — 실물 계약: POST /check/screen ─
# QA 판정기(normal/anomaly) + description. description 을 로컬 합성해 상태 식별.
DETECTION_MCP_URL=http://172.16.3.136:8103
DETECTION_MCP_MODEL=qwen2.5vl:7b
DETECTION_MCP_TIMEOUT=240
REMOTECTL_DETECTION_SCENARIO=screen_state_probe
