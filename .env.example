# remotectl 환경변수 예시 — 실제 값은 .env 로 복사해 채운다 (.env 는 커밋 금지)

# ── 구현체 선택 (config.Settings) ────────────────────────────────
# driver_backend: mock | mcp
REMOTECTL_DRIVER_BACKEND=mock
# sense_backend: mock | detection
REMOTECTL_SENSE_BACKEND=mock
# 맵 영속화 경로 (JSON)
REMOTECTL_MAP_STORE_PATH=./data/navmap.json
# press 후 화면 안정화 대기(ms)
REMOTECTL_SETTLE_MS=400

# ── remote-MCP (리모컨 제어) — 엔드포인트 미확정, [WIRE-*] ────────
# 사내망 HTTP. POST /press, GET /capture, POST /reset 가정
REMOTE_MCP_URL=http://172.16.3.136:8101
REMOTE_MCP_TOKEN=
REMOTE_MCP_TIMEOUT=10

# ── detection-MCP / VLM (화면 판정) — 엔드포인트 미확정, [WIRE-*] ─
# POST /classify 가정. CALIBRATION_PROMPT 가 최대 레버
DETECTION_MCP_URL=http://172.16.3.136:8103
DETECTION_MCP_TIMEOUT=30
CALIBRATION_PROMPT=
